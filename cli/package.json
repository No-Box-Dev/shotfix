{
  "name": "shotfix",
  "version": "0.1.0",
  "description": "Visual AI input — screenshot + fix for developers",
  "type": "module",
  "bin": {
    "shotfix": "dist/bin.js",
    "shotfix-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "widget/dist/shotfix.min.js"
  ],
  "scripts": {
    "build": "tsc",
    "build:widget": "cd ../widget && npm run build && mkdir -p ../cli/widget/dist && cp dist/shotfix.min.js ../cli/widget/dist/",
    "prepublishOnly": "npm run build:widget && npm run build",
    "start": "node dist/index.js"
  },
  "keywords": [
    "shotfix",
    "screenshot",
    "visual-ai",
    "auto-fix",
    "developer-tools",
    "ui-debug",
    "mcp",
    "model-context-protocol"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/No-Box-Dev/shotfix.git",
    "directory": "cli"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
